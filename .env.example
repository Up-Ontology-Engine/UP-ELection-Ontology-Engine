# ─────────────────────────────────────────────────────────────────────────────
# Gorakhpur KG — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Local: postgresql://postgres:postgres@localhost:5432/gorakhpur_db
# Neon.tech: postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/gorakhpur_db
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/gorakhpur_db
POSTGRES_POOL_SIZE=10

# ── Neo4j ────────────────────────────────────────────────────────────────────
# Local Docker: bolt://localhost:7687
# AuraDB: neo4j+s://xxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Redis ────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:xxxx@xxxx.upstash.io:6380
REDIS_URL=redis://localhost:6379


# Sarvam — reasoning / chat models: https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_h017uwtl_Zp5pzzdGJV6rWeHAAJRiZ4YT
SARVAM_REASONING_MODEL=sarvam-30b

# ── Bhashini (Hindi/Bhojpuri Translation) ────────────────────────────────────
# Register at: https://bhashini.gov.in/ulca/auth/register
# API docs: https://bhashini.gov.in/ulca/apidocs
BHASHINI_USER_ID=your_bhashini_user_id
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_PIPELINE_URL=https://dhruva-api.bhashini.gov.in/services/inference/pipeline

# ── YouTube ───────────────────────────────────────────────────────────────────
# Get at: https://console.cloud.google.com → YouTube Data API v3
# Free: 10,000 units/day
YOUTUBE_API_KEY=AIzaSy_xxxx

# ── Facebook / Meta ───────────────────────────────────────────────────────────
# Option A — Graph API token (recommended, most stable)
#   1. Go to https://developers.facebook.com → My Apps → Create App (type: Business)
#   2. Add "Pages API" product
#   3. Generate a Page Access Token or a long-lived User Access Token
#   4. Token needs: pages_read_engagement, pages_show_list (public pages are readable with any valid token)
#   Docs: https://developers.facebook.com/docs/graph-api/get-started
FACEBOOK_ACCESS_TOKEN=

# Option B — Playwright browser login (fallback when Graph API token is unavailable)
#   The scraper will log in headlessly and scroll page timelines.
#   Use a dedicated scraper account, not your personal Facebook.
FB_EMAIL=
FB_PASSWORD=

# ── Orchestration (Prefect) ───────────────────────────────────────────────────
# Prefect Cloud: https://app.prefect.cloud
# Leave empty to use local Prefect server
PREFECT_API_URL=
PREFECT_API_KEY=

# ── Security / PII ───────────────────────────────────────────────────────────
# 32-byte random salt for voter ID hashing
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
VOTER_HASH_SALT=replace_with_32_byte_random_hex_string

# ── App Config ────────────────────────────────────────────────────────────────
PILOT_AC_ID=GKP_URBAN
PILOT_AC_NAME=Gorakhpur Urban
PILOT_DISTRICT=Gorakhpur
PILOT_STATE=Uttar Pradesh

# API base URL (used by Streamlit to call FastAPI)
API_BASE_URL=http://localhost:8000

# NLP settings
NLP_CONFIDENCE_THRESHOLD=0.6
NLP_GEO_CONFIDENCE_THRESHOLD=0.75
NLP_BATCH_SIZE=50

# Path to local alias index
ALIAS_INDEX_PATH=data/seeds/gorakhpur_aliases.json
LEXICON_PATH=data/seeds/political_lexicon.json

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
